		"react-day-picker": "^9.14.0",
		"react-dom": "^19.2.4",
		"react-hook-form": "^7.72.0",
		"react-resizable-panels": "^4.10.0",
		"recharts": "3.8.0",
		"resend": "^6.9.4",
		"shadcn": "^4.5.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
