# This environment variable is used in Production and Preview environments to deploy your Convex project
# This variable is not needed in development.
# You can create a Production or Preview deploy key at https://dashboard.convex.dev/project/settings#production-deploy-keys
CONVEX_DEPLOY_KEY=

# Cloudinary (https://cloudinary.com/console)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=

# PostHog Analytics (https://posthog.com)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# Sentry Error Tracking (https://sentry.io)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Logging
LOG_LEVEL=info  # debug, info, warn, error, fatal

# Node Environment
NODE_ENV=development  # development, production
