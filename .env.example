# ─── Convex ───────────────────────────────────────────────────────────────────
# This environment variable is used in Production and Preview environments to deploy your Convex project
# This variable is not needed in development. Create deploy keys at:
# https://dashboard.convex.dev/project/settings#production-deploy-keys
CONVEX_DEPLOY_KEY=

# ─── App Configuration (Next.js side) ─────────────────────────────────────────
# Public URL of the deployed app (used by `APP_CONFIG.url` for the workspace
# URL preview during onboarding, og:url meta, etc.).
#
# Resolution order if NEXT_PUBLIC_APP_URL is unset:
#   1. VERCEL_PROJECT_PRODUCTION_URL  (set automatically on Vercel — production)
#   2. NEXT_PUBLIC_VERCEL_URL         (set automatically on Vercel — per-deploy)
#   3. http://localhost:3000          (local dev fallback)
#
# Setting this explicitly is recommended for production so you don't end up
# showing a per-deployment URL ("orbitly-pr-42.vercel.app") in the onboarding
# slug preview.
NEXT_PUBLIC_APP_URL=
# Optional white-label overrides
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_APP_DESCRIPTION=
NEXT_PUBLIC_PLATFORM_PREFIX=

# ─── Resend (transactional email) ─────────────────────────────────────────────
# https://resend.com/api-keys
#
# These run inside Convex (NOT Next.js). Set them with:
#   npx convex env set RESEND_API_KEY    "re_xxxxxxxxxxxxxxxxxx"
#   npx convex env set RESEND_FROM_EMAIL "Orbitly <invites@yourdomain.com>"
#   npx convex env set APP_PUBLIC_URL    "https://yourapp.com"
#
# Defaults if unset:
#   - RESEND_API_KEY unset       → invitation emails skip silently (the
#                                   inviter still sees an "invite link" in
#                                   the dialog and can copy/share it).
#   - RESEND_FROM_EMAIL unset    → uses "Orbitly <no-reply@orbitly.app>"
#   - APP_PUBLIC_URL unset       → uses "http://localhost:3000"
RESEND_API_KEY=
RESEND_FROM_EMAIL=
APP_PUBLIC_URL=
APP_PUBLIC_NAME=

# ─── PostHog Analytics (https://posthog.com) ──────────────────────────────────
# Required for analytics. PostHogProvider no-ops gracefully if PROJECT_TOKEN is unset.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# ─── Sentry Error Tracking (https://sentry.io) ────────────────────────────────
# Required for error tracking. All sentry.*.config.ts files no-op gracefully if DSN is unset.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Required for source-map upload during build (CI only):
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Optional tuning (defaults: prod 0.1, dev 1.0):
SENTRY_TRACES_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=

# ─── Auth providers (Convex Auth) ─────────────────────────────────────────────
# Set these in your Convex dashboard for production.
# Provider is disabled (warns at boot) if its env pair is unset.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Logging ──────────────────────────────────────────────────────────────────
# pino log level. Options: debug, info, warn, error, fatal
LOG_LEVEL=info

# ─── Node Environment ─────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Optional / future ────────────────────────────────────────────────────────
# Convex platform prefix for record codes (org platformOrgId). Defaults to "ORB".
# PLATFORM_PREFIX=ORB

# Cloudinary (https://cloudinary.com/console) — kept for future image-CDN use.
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
