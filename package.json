{
	"name": "flowbite",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "npm-run-all --parallel dev:frontend dev:backend",
		"dev:frontend": "next dev",
		"dev:backend": "convex dev",
		"predev": "convex dev --until-success && convex dev --once --run-sh \"node setup.mjs --once\" && convex dashboard",
		"build": "next build",
		"start": "next start",
		"format": "biome format --write .",
		"format:check": "biome format --check .",
		"lint-check": "biome lint --check .",
		"check": "biome check --apply .",
		"check:ci": "biome check .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run convex",
		"test:watch": "vitest convex",
		"test:ui": "vitest --ui convex",
		"test:frontend": "vitest run --config vitest.config.ts",
		"test:frontend:watch": "vitest --config vitest.config.ts",
		"test:frontend:ui": "vitest --ui --config vitest.config.ts",
		"test:frontend:coverage": "vitest run --coverage --config vitest.config.ts",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --debug",
		"test:all": "pnpm test && pnpm test:frontend && pnpm test:e2e"
	},
	"dependencies": {
		"@auth/core": "0.37.4",
		"@base-ui/react": "^1.3.0",
		"@convex-dev/auth": "^0.0.91",
		"@dnd-kit/core": "6.3.1",
		"@dnd-kit/sortable": "10.0.0",
		"@dnd-kit/utilities": "3.2.2",
		"@hookform/resolvers": "^5.2.2",
		"@payloadcms/plugin-mcp": "^3.83.0",
		"@posthog/next": "^0.1.0",
		"@sentry/nextjs": "^10.46.0",
		"@tanstack/react-table": "8.21.2",
		"@trigger.dev/sdk": "4.4.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"convex": "^1.38.0",
		"convex-helpers": "^0.1.114",
		"date-fns": "^4.1.0",
		"embla-carousel-react": "^8.6.0",
		"input-otp": "^1.4.2",
		"lucide-react": "^1.12.0",
		"next": "16.1.7",
